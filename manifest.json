{
  "manifest_version": 3,
  "name": "Canvas Batch File Upload",
  "version": "1.0",
  "description": "Select multiple files at once to upload to Canvas assignments",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "*://*.instructure.com/courses/*/assignments/*",
        "*://*.canvas.com/courses/*/assignments/*",
        "*://byu.instructure.com/courses/*/assignments/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
